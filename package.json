{
  "name": "nuxt-flutter-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "build:agent": "pnpm --filter aso-agent build",
    "generate": "pnpm --filter web generate",
    "preview": "pnpm --filter web preview",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "db:migrate": "pnpm --filter web db:migrate",
    "db:migrate:generate": "pnpm --filter web db:migrate:generate",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "test:e2e": "pnpm --filter web test:e2e",
    "test:components": "pnpm --filter web test:components",
    "publish:all": "pnpm -r publish"
  }
}
